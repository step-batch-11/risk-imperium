{
  "tasks": {
    "dev": "DEV_MODE='true' deno run -A --watch main.js",
    "start": "deno run -A --watch main.js",
    "test": "deno test -A --reporter=dot",
    "test:watch": "deno test -A --watch",
    "coverage": "deno test -A --reporter=dot --coverage",
    "detailed-coverage": {
      "command": "deno coverage --detailed",
      "dependencies": ["coverage"]
    },
    "lint": "deno lint --fix"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "hono": "npm:hono@^4.12.12"
  },
  "fmt": {
    "exclude": [
      "public/**/*.html",
      "public/**/*.css",
      "deno.*",
      "public/assets/*",
      "*.json"
    ]
  }
}
