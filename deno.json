{
  "tasks": {
    "dev": "deno run -A --watch main.js",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "coverage": "deno test -A --coverage",
    "detailed-coverage": {
      "command": "deno coverage --detailed",
      "dependencies": [
        "coverage"
      ]
    },

    "lint": "deno lint --fix"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "hono": "npm:hono@^4.12.9"
  }
}
